{
  "name": "skillcanvas",
  "private": true,
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "dev:api": "npm --workspace apps/api run dev",
    "dev:insights": "npm --workspace services/insights run dev"
  },
  "allowScripts": {
    "fsevents@2.3.3": true,
    "better-sqlite3@12.11.1": true
  }
}
